# If not running interactively, don't do anything
# case $- in
#     *i*) ;;
#       *) return;;
# esac

set -o pipefail

# Reload GPG agent (prompt password in text mode, not via the windows manager)
# gpg-connect-agent <<< RELOADAGENT 1>/dev/null 2>&1 &

# Default PATH
export PATH=~/conf/tools/diff-so-fancy:~/.cargo/bin:~/.nodejs/bin:~/.local/bin:~/.local/usr/bin:${PATH}
export NODE_PATH=~/.nodejs/lib/node_modules

# setting shell shitory
HISTFILE=~/.shell_history
HISTSIZE=1000
SAVEHIST=1000
HISTFILESIZE=2000

# favorite editor
export EDITOR=vim
export VISUAL=vim

# set terminal title
setttitle() {
    echo -ne "\033]0;$1\007"
}

# Disable STUPID non-breakable spaces when typing AltGr+Space
test -n "${DISPLAY}" && setxkbmap -option "nbsp:none"

# enable color support of ls and also add handy aliases
alias ls='ls --show-control-chars'
if [ -x /usr/bin/dircolors ]; then
    test -r ~/.dircolors && eval "$(dircolors -b ~/.dircolors)" || eval "$(dircolors -b)"
    alias ls='ls --color=auto --show-control-chars --quoting-style=escape'
    alias grep='grep --color=auto'
    alias fgrep='fgrep --color=auto'
    alias egrep='egrep --color=auto'
    alias less='less -r' # raw control characters
fi
if [ -e ~/.local/bin/nvim ]; then
    alias vim=~/.local/bin/nvim
fi

alias rg="rg -uuu -g '!.mypy_cache*' -g '!.pytest_cache' -g '!.venv*' -g '!__pycache__' -g '!.git'"
alias tmux='tmux -2 -u'
alias crontab='crontab -i' # crontab -r is such an evil typo to make...
# some more ls aliases
alias ll='ls -al'
alias l='ll'
# personal aliases
alias sks='ssh -nNTq -C -D 1080'
alias cmake='cmake -DCMAKE_EXPORT_COMPILE_COMMANDS=Y'
alias grep='grep --color --exclude-dir=.svn --exclude-dir=.git'  # show differences in colour and ignore .svn dirs
wchat() {
    session="weechat"
    if tmux has-session -t ${session} >&/dev/null
    then
            tmux attach-session -t ${session}
            return
    fi
    tmux new-session -s ${session} /usr/bin/weechat
    # tmux set-option -t ${session} status off
    tmux attach -t ${session}
}
alias vims='vim --servername vim'
alias vimr='vim --servername vim --remote'
alias vimdiff='nvim -d'
alias ia='~/conf/containers/ia/ia.sh'

set_prompt() {
    # Retrieve data for prompt
    local _p_user=$(whoami)
    local _p_hostname=$(hostname -s)
    test -n "${LOCAL_HOSTNAME}" && _p_hostname=${LOCAL_HOSTNAME}
    local _p_ssh=0
    test -n "${SSH_CLIENT}${SSH_CONNECTION}${SSH_TTY}" && _p_ssh=1
    local _p_screen=0
    test -n "${STY}" && _p_screen=1
    local _p_vim=0
    test -n "${VIMRUNTIME}${MYVIMRC}${VIM}" && _p_vim=1
    local _p_has_x=0
    test -n "${DISPLAY}" && _p_has_x=1
    local _p_container=0
    if [ -n "${SCHROOT_CHROOT_NAME}" ]; then
        test -z "${_p_user}" && _p_user="${SCHROOT_USER}"
        _p_hostname="${_p_hostname}#${SCHROOT_CHROOT_NAME}"
        _p_container=1
    fi
    local _p_root=0
    test $(id -u) -eq 0 && _p_root=1
    set_prompt_spe ${_p_ssh} ${_p_container} ${_p_screen} ${_p_vim} ${_p_has_x} ${_p_root} ${_p_user} ${_p_hostname}
}

if [ -n "${TMUX}" ]; then
    refresh() {
        dispcmd=$(tmux show-environment DISPLAY 2>/dev/null)
        if [ -n "${dispcmd}" -a "${dispcmd}" != "-DISPLAY" ]; then
            export ${dispcmd}
        fi
    }
fi

# source local file if relevant
test -f ~/.shellrc.local && source ~/.shellrc.local

set_prompt
unset -f set_prompt set_prompt_spe

# ---- Make `uv run <cmd> …` and `poetry run <cmd> …` complete <cmd>'s own
# arguments, instead of falling through to uv/poetry's generic completion.
#
# Strategy: source the tool's own completion script, save it under a backup
# name, then wrap it. When the user is past `<tool> run <cmd>`, we shift the
# completion context to <cmd> using bash-completion's `_command_offset`.
# Otherwise we delegate to the tool's original completion unchanged.
#
# Concretely: with the system `_pytest` completion from the bash-completion
# package, this restores `uv run pytest tests/foo.py::Bar::test_<TAB>` →
# class/method completion, without aliasing or wrapping pytest.
#
# Caveat: the heuristic treats the first non-option word after `run` as the
# command. If you pass a uv option that takes a separate value (e.g.
# `uv run --with pkg pytest …`), `pkg` will be misidentified as the command.
# Workaround: use the `--opt=value` form (`--with=pkg`), which is a single
# token and is correctly skipped.
#
# This is pure bash syntax but works in zsh too once `bashcompinit` is
# enabled and the bash-completion library has been sourced. The function is
# only defined here; the actual install calls live in ~/.bashrc / ~/.zshrc so
# they run *after* each shell has finished its own completion setup.
_install_run_passthrough_completion() {
    local tool=$1 gen_cmd=$2 native_name=$3
    command -v "$tool" >/dev/null 2>&1 || return
    eval "$($gen_cmd 2>/dev/null)" || return

    # Discover which function the tool's completion registered itself as.
    local main_fn
    main_fn=$(complete -p "$tool" 2>/dev/null | sed -n 's/.* -F \([^ ]\+\).*/\1/p')
    [ -n "$main_fn" ] || return

    # Save original under $native_name (only on first invocation).
    if ! declare -F "$native_name" >/dev/null; then
        eval "$(declare -f "$main_fn" | sed "1s/^$main_fn/$native_name/")"
    fi

    eval "
        $main_fn() {
            local i j
            for (( i=1; i<COMP_CWORD; i++ )); do
                [[ \${COMP_WORDS[i]} == run ]] || continue
                for (( j=i+1; j<COMP_CWORD; j++ )); do
                    [[ \${COMP_WORDS[j]} != -* ]] && { _command_offset \$j; return; }
                done
                break
            done
            $native_name \"\$@\"
        }
    "
}

if direnv version &> /dev/null; then
    eval "$(direnv hook bash)"
fi
